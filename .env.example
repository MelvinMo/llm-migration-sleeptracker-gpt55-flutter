# There is no runtime .env loading in Flutter. Backend URLs are passed at
# build/run time via --dart-define flags (see README). This file is a
# reference for the values to use.
#
#   flutter run --dart-define=API_ENCRYPTED_URL=https://your-backend-host.example.com \
#               --dart-define=API_UNENCRYPTED_URL=http://your-lan-ip:7000/api
#
# Copy this file to .env for your own notes if useful.
# Never commit real backend hostnames/IPs you consider private.

API_ENCRYPTED_URL=https://your-backend-host.example.com
API_UNENCRYPTED_URL=http://10.0.2.2:7000/api
